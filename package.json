{
  "name": "detox-demo",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "scripts": {
    "ios:dev": "react-native run-ios",
    "android:dev": "react-native run-android",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest --config jest.config.js --coverage",
    "detox:build:ios": "detox build --configuration ios.sim.debug",
    "detox:test:ios": "detox test --configuration ios.sim.debug",
    "detox:ios": "yarn run detox:build:ios && yarn run detox:test:ios",
    "detox:build:android": "detox build --configuration android.emu.debug",
    "detox:test:android": "detox test --configuration android.emu.debug",
    "detox:android": "yarn run detox:build:android && yarn run detox:test:android"
  },
  "dependencies": {
    "@react-native/new-app-screen": "0.84.0",
    "react": "19.2.3",
    "react-native": "^0.84.0",
    "react-native-safe-area-context": "^5.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "^20.1.1",
    "@react-native-community/cli-platform-android": "^20.1.3",
    "@react-native-community/cli-platform-ios": "^20.1.3",
    "@react-native/babel-preset": "0.84.0",
    "@react-native/eslint-config": "0.84.0",
    "@react-native/metro-config": "0.84.0",
    "@react-native/typescript-config": "^0.84.0",
    "@testing-library/react-native": "^12.1.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.9",
    "@types/react": "^19.2.0",
    "@types/react-test-renderer": "^19.1.0",
    "allure-commandline": "^2.36.0",
    "detox": "^20.40.2",
    "detox-allure2-adapter": "^1.0.0-alpha.35",
    "eslint": "^9.0.0",
    "expect": "^29.0.0",
    "jest": "^30.0.4",
    "jest-allure2-reporter": "^2.3.0",
    "prettier": "3.8.1",
    "react-test-renderer": "19.2.3",
    "sharp": "^0.34.5",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
